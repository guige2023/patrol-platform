# =============================================================================
# Patrol Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control!

# =============================================================================
# Database Configuration (Required)
# =============================================================================
# PostgreSQL password for the patrol database
PATROL_DB_PASSWORD=replace-with-a-strong-password

# =============================================================================
# Security Keys (Required)
# =============================================================================
# Django-style SECRET_KEY for session management and token signing
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-strong-secret-key

# 32-byte encryption key for sensitive data encryption (base64 encoded recommended)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key

# =============================================================================
# MinIO Object Storage (Required)
# =============================================================================
# MinIO root user for object storage
MINIO_ROOT_USER=patrol-minio
# MinIO root password - must be strong, at least 8 characters
MINIO_ROOT_PASSWORD=replace-with-a-strong-minio-password

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins for CORS
# For production, specify exact origins rather than using wildcard
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Meilisearch Search Engine (Required)
# =============================================================================
# Master key for Meilisearch - must be strong and match across services
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MEILISEARCH_KEY=replace-with-a-strong-meilisearch-key

# =============================================================================
# LibreOffice (Optional)
# =============================================================================
# Path to LibreOffice binary for document conversion
# Leave as 'libreoffice' if installed system-wide
LIBREOFFICE_CMD=libreoffice

# =============================================================================
# Initial Admin Password (Optional)
# =============================================================================
# Password for the initial admin user (admin@patrol.gov)
# If not set, a random password will be generated and printed to console
# IMPORTANT: Change this after first login!
ADMIN_PASSWORD=replace-with-admin-password

# =============================================================================
# Runtime Directory
# =============================================================================
# Directory for runtime files (uploads, backups, temp files)
# This is set automatically in Docker Compose - do not change
# RUNTIME_DIR=/app/runtime
